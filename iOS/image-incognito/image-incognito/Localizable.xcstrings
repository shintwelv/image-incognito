    "AI가 자동으로 얼굴을 찾아 마스킹해드립니다." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI automatically detects faces and applies masks."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La IA detecta automáticamente los rostros y aplica máscaras."
